{
    "swagger": "2.0",
    "info": {
        "title": "Chat Service API",
        "version": "1.0",
        "description": "Minimal API specification for chat-service"
    },
    "host": "localhost:4000",
    "basePath": "/",
    "schemes": [
        "http"
    ],
    "paths": {
        "/health": {
            "get": {
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "status": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/ws/chat": {
            "get": {
                "summary": "User WebSocket chat",
                "description": "Upgrades user's connection to WebSocket. Provide token as query param or header.",
                "parameters": [
                    {
                        "name": "token",
                        "in": "query",
                        "description": "JWT token",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "101": {
                        "description": "Switching Protocols"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        },
        "/ws/admin/{conversationId}": {
            "get": {
                "summary": "Admin WebSocket for a conversation",
                "description": "Upgrades admin connection to join a conversation room. Provide atoken as query param or header.",
                "parameters": [
                    {
                        "name": "conversationId",
                        "in": "path",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "name": "atoken",
                        "in": "query",
                        "description": "Admin JWT token",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "101": {
                        "description": "Switching Protocols"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        },
        "/api/chat/pending": {
            "get": {
                "summary": "List conversations waiting for admin",
                "parameters": [
                    {
                        "name": "atoken",
                        "in": "header",
                        "description": "Admin token",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "success": {
                                    "type": "boolean"
                                },
                                "conversations": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/definitions/Conversation"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        },
        "/api/chat/history/{conversationId}": {
            "get": {
                "summary": "Get conversation history",
                "parameters": [
                    {
                        "name": "conversationId",
                        "in": "path",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "name": "token",
                        "in": "header",
                        "description": "User token",
                        "required": false,
                        "type": "string"
                    },
                    {
                        "name": "atoken",
                        "in": "header",
                        "description": "Admin token",
                        "required": false,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "schema": {
                            "$ref": "#/definitions/Conversation"
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "403": {
                        "description": "Forbidden"
                    },
                    "404": {
                        "description": "Not Found"
                    }
                }
            }
        },
        "/api/chat/close/{conversationId}": {
            "patch": {
                "summary": "Close conversation",
                "parameters": [
                    {
                        "name": "conversationId",
                        "in": "path",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "name": "atoken",
                        "in": "header",
                        "description": "Admin token",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Conversation closed"
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "500": {
                        "description": "Internal Server Error"
                    }
                }
            }
        }
    },
    "definitions": {
        "Message": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "sender": {
                    "type": "string"
                },
                "senderId": {
                    "type": "string"
                },
                "content": {
                    "type": "string"
                },
                "metadata": {
                    "type": "object"
                },
                "createdAt": {
                    "type": "string",
                    "format": "date-time"
                }
            }
        },
        "Conversation": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "userID": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "botState": {
                    "type": "string"
                },
                "adminId": {
                    "type": "string"
                },
                "messages": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/Message"
                    }
                },
                "createdAt": {
                    "type": "string",
                    "format": "date-time"
                },
                "updatedAt": {
                    "type": "string",
                    "format": "date-time"
                }
            }
        }
    }
}